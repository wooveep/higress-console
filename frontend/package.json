{
  "name": "aigateway-console-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "AIGateway console frontend rebuilt with Vue 3 + Vite",
  "scripts": {
    "prepare": "cd .. && husky install frontend/.husky",
    "dev": "vite",
    "start": "vite",
    "typecheck": "vue-tsc --noEmit",
    "pre-commit": "npm run typecheck",
    "lint:lint-staged": "npm run pre-commit",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "check-i18n": "node scripts/check-i18n.js",
    "check-i18n:verbose": "node scripts/check-i18n.js --verbose",
    "check-i18n:update-baseline": "node scripts/check-i18n.js --update-baseline",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/route-pages.smoke.spec.ts"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.8.4",
    "js-yaml": "^4.1.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.1",
    "husky": "^8.0.3",
    "typescript": "^5.8.2",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.3",
    "vue-tsc": "^2.2.8"
  }
}
